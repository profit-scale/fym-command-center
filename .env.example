# Backend API base URL — set this on Netlify and locally for dev
# Production: https://api.fymfinancial.com (Caddy reverse-proxied to VPS port 8080)
# Local dev:  https://emphasis-mitchell-casual-converted.trycloudflare.com (current tunnel)
VITE_API_BASE=https://emphasis-mitchell-casual-converted.trycloudflare.com

# Admin bearer token for the /api/admin/* endpoints (only used in dev / privileged users)
# Generate fresh on the VPS: cat /opt/fym-agent/.admin-token
VITE_ADMIN_TOKEN=
